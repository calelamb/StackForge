        "type": "multiselect"
      },
      {
        "id": "filter_4",
        "name": "Select Shipping Mode",
        "column": "shipping_mode",
        "type": "multiselect"
      },
      {
        "id": "filter_5",
        "name": "Order Date Range",
        "column": "order_date",
        "type": "date_range"
      }
    ]
  },
