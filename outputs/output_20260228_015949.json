{
  "app_definition": {
    "app_title": "Sales Trend Dashboard",
    "app_description": "This dashboard visualizes the sales trend over time based on the supply chain dataset.",
    "components": [
      {
        "id": "chart_1",
        "type": "line_chart",
        "title": "Sales Trend Over Time",
        "sql_query": "SELECT strftime(order_date, '%Y-%m') AS month, SUM(total_cost) AS total_sales FROM supply_chain GROUP BY month ORDER BY month ASC",
        "config": {
          "x_axis": "month",
          "y_axis": "total_sales",
          "format": "currency"
        }
      },
      {
        "id": "table_1",
        "type": "table",
        "title": "Sales Data Table",
        "sql_query": "SELECT order_id, order_date, supplier, region, product, category, quantity, unit_cost, total_cost FROM supply_chain ORDER BY order_date DESC",
        "config": {
          "columns": [
            "order_id",
            "order_date",
            "supplier",
            "region",
            "product",
            "category",
            "quantity",
            "unit_cost",
            "total_cost"
          ],
          "sort_column": "order_date",
          "sort_order": "desc"
        }
      }
    ],
    "filters": [
      {
        "id": "filter_1",
        "name": "Select Supplier",
        "column": "supplier",
        "type": "multiselect"
      },
      {
        "id": "filter_2",
        "name": "Select Region",
        "column": "region",
        "type": "multiselect"
      },
      {
        "id": "filter_3",
