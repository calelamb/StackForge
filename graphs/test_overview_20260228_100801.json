          "title": "Avg. Delivery Time (Days)",
          "type": "kpi_card",
          "id": "kpi_avg_delivery",
          "sql_query": "SELECT AVG(delivery_days) as avg_delivery_days FROM supply_chain",
          "config": {
            "value_column": "avg_delivery_days",
            "metric_name": "Average Delivery Days"
          }
        },
        {
          "config": {
            "format": "percentage",
            "value_column": "on_time_rate_pct",
            "metric_name": "On-Time Rate"
          },
          "sql_query": "SELECT (SUM(on_time_delivery) * 100.0 / COUNT(*)) as on_time_rate_pct FROM supply_chain",
          "id": "kpi_on_time_rate",
          "type": "kpi_card",
          "title": "On-Time Delivery Rate (%)"
        },
        {
          "type": "kpi_card",
          "id": "kpi_delayed_count",
          "title": "Total Delayed Orders",
          "config": {
            "value_column": "delayed_count",
            "metric_name": "Total Delayed Orders"
          },
          "sql_query": "SELECT COUNT(*) as delayed_count FROM supply_chain WHERE on_time_delivery = 0"
        },
        {
          "type": "line_chart",
          "id": "delayed_trend_chart",
          "title": "Delayed Shipments Trend (Monthly)",
          "config": {
            "y_axis": "delayed_orders",
            "x_axis": "order_month"
          },
          "sql_query": "SELECT strftime(CAST(order_date AS DATE), '%Y-%m') as order_month, COUNT(*) as delayed_orders FROM supply_chain WHERE on_time_delivery = 0 GROUP BY 1 ORDER BY 1"
        },
        {
          "sql_query": "SELECT region, AVG(delivery_days) as avg_delay FROM supply_chain WHERE on_time_delivery = 0 GROUP BY 1 ORDER BY 2 DESC",
          "config": {
            "x_axis": "region",
            "y_axis": "avg_delay"
          },
          "title": "Avg. Delay Duration by Region (Days)",
          "type": "bar_chart",
          "id": "delay_by_region_chart"
        },
        {
          "title": "Delayed Orders by Shipping Mode",
          "id": "delay_by_mode_chart",
          "type": "pie_chart",
          "sql_query": "SELECT shipping_mode, COUNT(*) as delay_count FROM supply_chain WHERE on_time_delivery = 0 GROUP BY 1 ORDER BY 2 DESC",
          "config": {
            "x_axis": "shipping_mode",
            "y_axis": "delay_count"
          }
        },
        {
          "sql_query": "SELECT supplier, COUNT(*) as total_orders, SUM(CASE WHEN on_time_delivery = 0 THEN 1 ELSE 0 END) as delayed_orders, ROUND(AVG(delivery_days), 2) as avg_delivery_days, ROUND(AVG(defect_rate), 2) as avg_defect_rate FROM supply_chain GROUP BY 1 ORDER BY 3 DESC",
          "config": {
            "sort_column": "delayed_orders",
            "sort_order": "desc",
            "columns": [
              "supplier",
              "total_orders",
              "delayed_orders",
              "avg_delivery_days",
              "avg_defect_rate"
            ]
          },
          "title": "Supplier Reliability Ranking",
          "type": "table",
          "id": "supplier_performance_table"
        }
