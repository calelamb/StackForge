{
  "app_definition": {
    "app_title": "Sales Trend Dashboard",
    "app_description": "This dashboard visualizes the sales trend over time based on the supply chain dataset.",
    "components": [
      {
        "id": "line_chart_1",
        "type": "line_chart",
        "title": "Sales Trend Over Time",
        "sql_query": "SELECT strftime(order_date, '%Y-%m') AS month, SUM(total_cost) AS total_sales FROM supply_chain GROUP BY month ORDER BY month",
        "config": {
          "x_axis": "month",
          "y_axis": "total_sales",
          "format": "currency"
        }
      },
      {
        "id": "kpi_card_1",
        "type": "kpi_card",
        "title": "Total Sales",
        "sql_query": "SELECT SUM(total_cost) AS total_sales FROM supply_chain",
        "config": {
          "value_column": "total_sales",
          "metric_name": "Total Sales",
          "format": "currency"
        }
      }
    ],
    "filters": [
      {
        "id": "filter_supplier",
        "name": "Supplier",
        "column": "supplier",
        "type": "multiselect"
      },
      {
        "id": "filter_region",
        "name": "Region",
        "column": "region",
        "type": "multiselect"
      },
      {
        "id": "filter_product",
        "name": "Product",
        "column": "product",
        "type": "multiselect"
      },
      {
        "id": "filter_category",
        "name": "Category",
        "column": "category",
        "type": "multiselect"
      },
      {
        "id": "filter_date",
        "name": "Order Date",
        "column": "order_date",
        "type": "date_range"
      }
    ]
  },
